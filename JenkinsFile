
pipeline{
    agent any
    
    environment{
        DOCKER_IMAGE = "officialamit1232/capstone:latest"
        GITHUB_URL = "https://github.com/aj1232/Devops_Project_2.git"
        DOCKERHUB_USERNAME = "officialamit1232"
        DOCKERHUB_PASS = "Zxcvbnm@67663"
    }
    stages {
        stage('Build Docker Image'){
            steps{
                echo "Building docker image ..."
                sh 'docker build -t ${DOCKER_IMAGE} .'
                echo "Created docker image successfully !!"
            }
        }
        
        stage('Push Docker Image'){
            steps{
                echo "Pushing docker image to docker hub ..."
                sh 'docker login -u ${DOCKERHUB_USERNAME} -p ${DOCKERHUB_PASS}'
                sh 'docker push ${DOCKER_IMAGE}'
                echo "Docker image uplaoded on docker hub !!"
            }
        }
        stage('Copy Docker Image') {
            agent{
                label 'k8s_master'
            }
            options {
                skipDefaultCheckout()
            }
            steps{
                script {
                    def labels = ['k8s_worker1', 'k8s_worker2']
                    for(label in labels){
                        echo "Pulling docker image and running container on ${label} ..."
                        node(label){
                            sh 'sudo docker rmi ${DOCKER_IMAGE}'
                            sh 'sudo docker pull ${DOCKER_IMAGE}'
                        }
                        echo "Added docker image on ${label} !!"
                    }
                }
            }
        }
        stage('Deployment') {
            agent{
                label 'k8s_master'
            }
            options {
                skipDefaultCheckout()
            }
            steps{
                echo "Deploying docker images on servers"
                sh ''
                sh 'scp jenkins@100.48.63.125:/var/lib/jenkins/workspace/Capstone_2/*.yml /home/ec2-user/workspace/Capstone_2/'
                sh 'kubectl delete -f deployment.yml'
                sh 'kubectl delete -f service.yml'
                sh 'sleep 20'
                sh 'kubectl apply -f deployment.yml'
                sh 'kubectl apply -f service.yml'
                echo "Deployed docker images on servers !!"
            }
        }
    }
}
